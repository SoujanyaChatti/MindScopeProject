{
  "name": "mindscope-backend",
  "version": "1.0.0",
  "description": "AI-Assisted Depression Detection and Lifestyle Recommendation System - Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/(routes|services|middleware|models)",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:chat": "jest --testPathPattern=chat",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "keywords": [
    "mental-health",
    "ai",
    "depression-detection",
    "phq-9"
  ],
  "author": "MindScope Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "googleapis": "^169.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-node": "^30.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4"
  }
}
